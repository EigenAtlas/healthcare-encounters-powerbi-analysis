	column 'Quarter-Year Sort' = (YEAR([Date]) * 10) + QUARTER([Date])
		formatString: 0
		lineageTag: 6ddd7fea-5b23-405c-ad6c-1daa7833f67a
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	partition Dim_dates = calculated
		mode: import
		source =
				
				-- 1. Find the earliest start date in either encounters or procedures
				VAR MinYearVal = YEAR(MIN(MIN('encounters'[start date]), MIN('encounters'[start date])))
				
				-- 2. Find the latest stop date in either encounters or procedures
				VAR MaxYearVal = YEAR(MAX(MAX('encounters'[STOP]), MAX('encounters'[STOP])))
				
				-- 3. Create a continuous range of full calendar years
				VAR CalendarStart = DATE(MinYearVal, 1, 1)
				VAR CalendarEnd = DATE(MaxYearVal, 12, 31)
				
				RETURN
				ADDCOLUMNS(
				    CALENDAR(CalendarStart, CalendarEnd),
				    "Year", YEAR([Date]),
				    "Month Number", MONTH([Date]),
				    "Month Name", FORMAT([Date], "mmmm"),
				    "Month Short", FORMAT([Date], "mmm"),
				    "Month-Year", FORMAT([Date], "mmm yyyy"),
				    "Month-Year Sort", YEAR([Date]) * 100 + MONTH([Date]),
				    "Quarter", "Q" & QUARTER([Date]),
				    "Quarter-Year", "Q" & QUARTER([Date]) & " " & YEAR([Date]),
				    "Week Number", WEEKNUM([Date]),
				    "Day of Month", DAY([Date]),
				    "Day of Week Number", WEEKDAY([Date], 2), -- 1 (Mon) to 7 (Sun)
				    "Day of Week Name", FORMAT([Date], "dddd"),
				    "Day of Week Short", FORMAT([Date], "ddd"),
				    "Is Weekend", IF(WEEKDAY([Date], 2) >= 6, "Weekend", "Weekday")
				)

	annotation PBI_Id = 537d649b299e46a29b86646bea6adb0a

