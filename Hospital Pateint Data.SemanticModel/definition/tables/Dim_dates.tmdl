table Dim_dates
	lineageTag: 594d5ffc-7325-4827-8eeb-0011a2ae4711

	measure 'test name' = CALCULATE(VALUES(payers[NAME]),ALL(payers[NAME]))
		lineageTag: 74424339-e65d-417e-9126-66102ddeb129

	measure 'test 2 name' =
			
			CALCULATE(
			    AVERAGE(encounters[TOTAL_CLAIM_COST]),
			    REMOVEFILTERS(payers[NAME])
			)
		lineageTag: a5701a54-d6d3-44fa-bf3e-f44a7c50695a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Difference Label' =
			
			SWITCH(
			    TRUE(),
			    [Savings vs All Payers] > 0, "% Below All-Payer Avg",
			    [Savings vs All Payers] < 0, "% Above All-Payer Avg",
			    "% Difference vs. Avg"
			)
		lineageTag: cace298d-392b-4c18-a831-4a76b9b6c48d

